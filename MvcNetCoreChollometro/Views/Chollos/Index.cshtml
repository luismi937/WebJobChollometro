@model List<Chollo>

@{
    ViewData["Title"] = "Chollos";
}

<style>
    .chollo-page {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #111827 100%);
        border-radius: 18px;
        padding: 2rem;
        color: #e2e8f0;
        box-shadow: 0 14px 35px rgba(0, 0, 0, 0.25);
    }

    .chollo-title {
        font-weight: 800;
        font-size: 2.2rem;
        margin-bottom: .4rem;
        color: #f8fafc;
    }

    .chollo-counter {
        display: inline-block;
        background-color: rgba(56, 189, 248, 0.18);
        border: 1px solid rgba(56, 189, 248, 0.4);
        color: #67e8f9;
        border-radius: 999px;
        padding: .4rem .9rem;
        margin-bottom: 1.2rem;
        font-weight: 600;
    }

    .chollo-card {
        background: #ffffff;
        color: #111827;
        border: none;
        border-radius: 14px;
        margin-bottom: 1rem;
        padding: 1rem 1.2rem;
        box-shadow: 0 8px 22px rgba(15, 23, 42, 0.18);
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .chollo-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.24);
    }

    .chollo-card h2 {
        color: #0f172a;
        font-size: 1.3rem;
        margin-bottom: .8rem;
    }

    .btn-chollo {
        border: none;
        border-radius: 999px;
        padding: .45rem 1rem;
        background: linear-gradient(90deg, #06b6d4, #2563eb);
        color: white;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        margin-bottom: .8rem;
    }

    .btn-chollo:hover {
        color: white;
        filter: brightness(1.08);
    }

    .chollo-desc {
        color: #334155;
        line-height: 1.55;
    }
</style>

<div class="chollo-page">
    <h1 class="chollo-title">🔥 Web Job Chollometro</h1>
    <div class="chollo-counter">Número de chollos: @Model.Count</div>

    @foreach (Chollo chollo in Model)
    {
        <div class="chollo-card">
            <h2>@chollo.Titulo</h2>
            <p>
                <a class="btn-chollo" href="@chollo.Link" target="_blank" rel="noopener noreferrer">Ir al chollo</a>
            </p>
            <div class="chollo-desc">@Html.Raw(chollo.Descripcion)</div>
        </div>
    }
</div>
